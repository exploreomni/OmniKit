{
  "name": "omnikit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "OmniKit — a self-contained, local-first Omni admin workspace that runs in your browser.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && tsx server/start.ts",
    "serve": "tsx server/start.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "test:dashboard-downloads": "tsx --test tests/dashboard-downloads.test.ts",
    "test:dashboard-migration": "tsx --test tests/dashboard-migration-wizard.test.ts",
    "test:migration-planner": "tsx --test tests/migration-planner.test.ts",
    "test:model-migrator": "tsx --test tests/model-migrator.test.ts",
    "test:instance-dashboard": "tsx --test tests/instance-dashboard.test.ts",
    "test:user-health": "tsx --test tests/user-health.test.ts",
    "test:security": "tsx --test tests/security-regression.test.ts",
    "test:deck-builder": "tsx --test tests/deck-builder.test.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "security:check": "npm run security:audit && npm run test:security && npm run test:dashboard-migration && npm run test:migration-planner && npm run test:model-migrator && npm run test:instance-dashboard && npm run test:user-health && npm run test:dashboard-downloads && npm run test:deck-builder && npm run typecheck && npm run typecheck:node && npm run lint && npm run build"
  },
  "dependencies": {
    "apache-arrow": "^21.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^6.4.2"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
